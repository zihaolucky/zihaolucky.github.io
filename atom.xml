---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ site.url }}{{ site.feed }}" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}" rel="alternate" type="text/html" />
  <updated>{% if site.posts.size > 0 %}{{ site.posts.first.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>{{ site.author.name }}</name>
    {% if site.author.email and site.author.email != "" %}
    <email>{{ site.author.email }}</email>
    {% endif %}
  </author>

  {% assign feed_count = 0 %}
  {% for post in site.posts %}
  {% unless post.path contains "template" or post.translation %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html"/>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ post.url }}</id>
    {% if post.description %}
    <summary type="text">{{ post.description | xml_escape }}</summary>
    {% endif %}
    {% if post.categories.size > 0 %}
    <category term="{{ post.categories | first | xml_escape }}"/>
    {% endif %}
    <content type="html">{{ post.content | xml_escape }}</content>
  </entry>
  {% assign feed_count = feed_count | plus: 1 %}
  {% if feed_count >= 20 %}{% break %}{% endif %}
  {% endunless %}
  {% endfor %}
</feed>
